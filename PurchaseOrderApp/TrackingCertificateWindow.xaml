<Window x:Class="PurchaseOrderApp.TrackingCertificateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PurchaseOrderApp.ViewModels"
        mc:Ignorable="d"
        Title="Tracking Certificates"
        Height="980"
        Width="1540"
        MinHeight="900"
        MinWidth="1280"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Window.DataContext>
        <vm:WialonTrackingViewModel />
    </Window.DataContext>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="76"
                            Height="76"
                            CornerRadius="18"
                            Background="White"
                            BorderBrush="#FFFFFF"
                            BorderThickness="1"
                            Padding="12"
                            Margin="0,0,16,0">
                        <Image Source="Assets/logo.png"
                               Stretch="Uniform" />
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="TRACKING CERTIFICATES"
                                   FontSize="28"
                                   FontWeight="Bold" />
                        <TextBlock Text="Load units from Wialon, select a vehicle, and export a matching installation certificate."
                                   Margin="0,6,0,0"
                                   FontSize="13.5"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Button Content="Back to Menu"
                            Width="140"
                            Margin="0,0,12,0"
                            Click="OnBackToMenu" />
                    <Button Content="Load Units"
                            Width="140"
                            Margin="0,0,12,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding LoadUnitsCommand}" />
                    <Button Content="Bulk Export Client"
                            Width="170"
                            Margin="0,0,12,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding BulkExportCertificatesForClientCommand}" />
                    <Button Content="Open Builder"
                            Width="150"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="OnOpenCertificateBuilder" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Style="{StaticResource CardBorderStyle}"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Certificate Workflow"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="This module uses the saved Wialon connection, reads a unit's fields, and opens the certificate builder for export."
                                   Margin="0,6,0,12"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" />

                        <Button Content="Load Units"
                                Margin="0,12,0,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding LoadUnitsCommand}" />
                        <Button Content="Bulk Export Selected Client"
                                Margin="0,10,0,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding BulkExportCertificatesForClientCommand}" />
                        <Button Content="Open Selected Unit"
                                Margin="0,10,0,0"
                                Click="OnOpenCertificateBuilder" />
                        <TextBlock Text="Bulk export uses the selected Account filter and saves one PDF per unit into a client batch folder."
                                   Margin="0,10,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}"
                        Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Filters"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Filter by account and search by unit name, unique ID, phone number, unit ID, or account label."
                                   Margin="0,6,0,10"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Account"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <ComboBox ItemsSource="{Binding AccountFilters}"
                                  SelectedItem="{Binding SelectedAccountFilter}"
                                  DisplayMemberPath="DisplayText"
                                  Height="38" />

                        <TextBlock Text="Search"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Margin="0,14,0,6" />
                        <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="40"
                                 VerticalContentAlignment="Center"
                                 FontSize="14" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Selection"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" />

                        <Border Margin="0,14,0,0"
                                Background="{StaticResource AccentSoftBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="SELECTED UNIT"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBlock Text="{Binding SelectedUnit.Name, TargetNullValue=No unit selected}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedUnit.AccountDisplay, StringFormat=Account: {0}, TargetNullValue=Account: N/A}"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedUnit.UniqueIdDisplay, StringFormat=Unique ID: {0}, TargetNullValue=Unique ID: N/A}"
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="2"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="20,18,20,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Available Units"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="Double-click a unit or use Open Builder to continue to the certificate builder."
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="{StaticResource CardTintBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,8"
                                VerticalAlignment="Top">
                            <TextBlock Text="{Binding VisibleUnitCount, StringFormat={}{0} matching units}"
                                       Foreground="{StaticResource SecondaryTextBrush}" />
                        </Border>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="16,0,16,12"
                            Padding="16,14"
                            CornerRadius="14"
                            Background="{StaticResource AccentSoftBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Viewbox Width="24"
                                     Height="24"
                                     VerticalAlignment="Top">
                                <Grid Width="24"
                                      Height="24"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <RotateTransform />
                                    </Grid.RenderTransform>

                                    <Ellipse Width="24"
                                             Height="24"
                                             Stroke="{StaticResource AccentBrush}"
                                             StrokeThickness="2"
                                             Opacity="0.2" />
                                    <Path Data="M 12,1 A 11,11 0 0 1 23,12"
                                          Stroke="{StaticResource AccentBrush}"
                                          StrokeThickness="2.6"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round" />

                                    <Grid.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                     From="0"
                                                                     To="360"
                                                                     Duration="0:0:1.1" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Grid.Triggers>
                                </Grid>
                            </Viewbox>

                            <StackPanel Grid.Column="1"
                                        Margin="14,0,0,0">
                                <TextBlock Text="Loading units from Wialon"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource AccentDarkBrush}" />
                                <TextBlock Text="{Binding StatusMessage}"
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextWrapping="Wrap" />
                                <ProgressBar Margin="0,12,0,0"
                                             Height="6"
                                             Minimum="0"
                                             Maximum="100"
                                             IsIndeterminate="True" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="2"
                              Margin="16,0,16,16"
                              ItemsSource="{Binding FilteredUnits}"
                              SelectedItem="{Binding SelectedUnit}"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              MouseDoubleClick="OnUnitDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name"
                                                Binding="{Binding Name}"
                                                Width="2.2*" />
                            <DataGridTextColumn Header="Account"
                                                Binding="{Binding AccountDisplay}"
                                                Width="220" />
                            <DataGridTextColumn Header="Unique ID"
                                                Binding="{Binding UniqueIdDisplay}"
                                                Width="1.2*" />
                            <DataGridTextColumn Header="Phone"
                                                Binding="{Binding PhoneNumberDisplay}"
                                                Width="1.0*" />
                            <DataGridTextColumn Header="Last Message"
                                                Binding="{Binding LastMessageDisplay}"
                                                Width="180" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
