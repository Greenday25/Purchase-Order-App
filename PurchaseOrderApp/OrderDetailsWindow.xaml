<Window x:Class="PurchaseOrderApp.OrderDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Order Details"
        Height="780"
        Width="1280"
        MinHeight="680"
        MinWidth="1100"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding OrderNumber, TargetNullValue=Order Details}"
                       FontSize="24"
                       FontWeight="Bold" />
            <TextBlock Text="{Binding OrderStatus, StringFormat=Status: {0}, TargetNullValue=Status: }"
                       Margin="0,4,0,0"
                       Foreground="#666666" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,16,0,16"
                Padding="14"
                BorderBrush="#D6D6D6"
                BorderThickness="1"
                Background="#F7F7F7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Date:" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{Binding Date, StringFormat=dd/MM/yyyy}" Margin="0,0,12,0" />

                <TextBlock Grid.Column="2" Text="Company:" FontWeight="SemiBold" />
                <TextBlock Grid.Column="3" Text="{Binding CompanyName}" TextWrapping="Wrap" />

                <TextBlock Grid.Row="1" Text="Bill To:" FontWeight="SemiBold" Margin="0,10,0,0" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BillTo}" Margin="0,10,12,0" TextWrapping="Wrap" />

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Reference:" FontWeight="SemiBold" Margin="0,10,0,0" />
                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding Reference}" Margin="0,10,0,0" TextWrapping="Wrap" />

                <TextBlock Grid.Row="2" Text="Address:" FontWeight="SemiBold" Margin="0,10,0,0" />
                <TextBlock Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding BillToAddress}" Margin="0,10,0,0" TextWrapping="Wrap" />

                <TextBlock Grid.Row="3" Text="Total:" FontWeight="SemiBold" Margin="0,10,0,0" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TotalAmount, StringFormat=N2}" Margin="0,10,12,0" />
                <TextBlock Grid.Row="3" Grid.Column="2" Text="Signed Order:" FontWeight="SemiBold" Margin="0,10,0,0" />
                <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding SignedOrderFileName}" Margin="0,10,0,0" TextWrapping="Wrap" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.1*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>

            <Border BorderBrush="#D6D6D6"
                    BorderThickness="1"
                    Padding="8">
                <DataGrid ItemsSource="{Binding Lines}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="90" />
                        <DataGridTextColumn Header="Part No." Binding="{Binding PartNumber}" Width="140" />
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                        <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat=N2}" Width="120" />
                        <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotal, StringFormat=N2}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="2"
                    BorderBrush="#D6D6D6"
                    BorderThickness="1"
                    Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Selected Order Workflow"
                                   FontSize="18"
                                   FontWeight="Bold" />
                        <TextBlock Text="Manage approval, documents, and deletion for this order from one place."
                                   Margin="0,4,0,14"
                                   Foreground="#666666"
                                   TextWrapping="Wrap" />

                        <Border Padding="12"
                                Background="#F7F7F7"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding OrderNumber}"
                                           FontSize="16"
                                           FontWeight="Bold" />
                                <TextBlock Text="{Binding CompanyName}"
                                           Margin="0,4,0,0"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Reference, StringFormat=Reference: {0}}"
                                           Margin="0,6,0,0"
                                           Foreground="#555555"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding OrderStatus, StringFormat=Current Status: {0}}"
                                           Margin="0,6,0,0"
                                           Foreground="#555555" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Status Actions"
                                   FontWeight="Bold"
                                   Margin="0,16,0,8" />

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Manager and Director Approval"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ApprovalStatus}"
                                       VerticalAlignment="Center"
                                       Foreground="#555555" />
                        </Grid>
                        <Button Content="Mark Approved"
                                Height="32"
                                Click="OnMarkApproved" />

                        <Grid Margin="0,14,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Rejected"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding RejectionStatus}"
                                       VerticalAlignment="Center"
                                       Foreground="#555555" />
                        </Grid>
                        <Button Content="Mark Rejected"
                                Height="32"
                                Click="OnMarkRejected" />

                        <TextBlock Text="Documents"
                                   FontWeight="Bold"
                                   Margin="0,18,0,8" />

                        <TextBlock Text="Signed Order"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SignedOrderFileName}"
                                   Margin="0,4,0,8"
                                   Foreground="#555555"
                                   TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Upload Signed Order"
                                    Width="150"
                                    Height="32"
                                    Margin="0,0,8,0"
                                    Click="OnUploadSignedOrder" />
                            <Button Content="Open"
                                    Width="80"
                                    Height="32"
                                    IsEnabled="{Binding HasSignedOrder}"
                                    Click="OnOpenSignedOrder" />
                        </StackPanel>

                        <TextBlock Text="Invoice"
                                   FontWeight="SemiBold"
                                   Margin="0,16,0,0" />
                        <TextBlock Text="{Binding InvoiceFileName}"
                                   Margin="0,4,0,8"
                                   Foreground="#555555"
                                   TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Upload Invoice"
                                    Width="150"
                                    Height="32"
                                    Margin="0,0,8,0"
                                    Click="OnUploadInvoice" />
                            <Button Content="Open"
                                    Width="80"
                                    Height="32"
                                    IsEnabled="{Binding HasInvoice}"
                                    Click="OnOpenInvoice" />
                        </StackPanel>

                        <TextBlock Text="Order Maintenance"
                                   FontWeight="Bold"
                                   Margin="0,18,0,8" />
                        <TextBlock Text="Orders can be deleted until they reach the completed state."
                                   Margin="0,0,0,8"
                                   Foreground="#666666"
                                   TextWrapping="Wrap" />
                        <Button Content="Delete Order"
                                Height="32"
                                IsEnabled="{Binding CanDelete}"
                                Click="OnDeleteOrder" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Close"
                    Width="100"
                    Height="32"
                    Click="OnCloseWindow" />
        </StackPanel>
    </Grid>
</Window>
