<Window x:Class="PurchaseOrderApp.OrderDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Order Details"
        Height="820"
        Width="1380"
        MinHeight="720"
        MinWidth="1120"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroCardStyle}"
                Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>

                <Border Width="78"
                        Height="78"
                        CornerRadius="16"
                        Background="White"
                        BorderBrush="#FFFFFF"
                        BorderThickness="1"
                        Padding="12"
                        Margin="0,0,16,0">
                    <Image Source="Assets/logo.png"
                           Stretch="Uniform" />
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding OrderNumber, StringFormat=Order {0}, TargetNullValue=Order Details}"
                               FontSize="24"
                               FontWeight="Bold" />
                    <StackPanel Orientation="Horizontal"
                                Margin="0,8,0,0">
                        <TextBlock Text="{Binding OrderStatus, StringFormat=Status: {0}, TargetNullValue=Status: Pending Approval}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentDarkBrush}" />
                        <TextBlock Text="{Binding Date, StringFormat=  |  {0:dd/MM/yyyy}}"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="2"
                        Background="#FFFFFFCC"
                        BorderBrush="#FFFFFF"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14,10"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Company"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBlock Text="{Binding CompanyName}"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Margin="16,0,0,0">
                            <TextBlock Text="Total"
                                       Style="{StaticResource FieldLabelStyle}"
                                       HorizontalAlignment="Right" />
                            <TextBlock Text="{Binding TotalAmount, StringFormat=R {0:N2}}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,14,0,14"
                Style="{StaticResource CardBorderStyle}"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="1.1*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Bill To"
                               Style="{StaticResource FieldLabelStyle}" />
                    <TextBlock Text="{Binding BillTo}"
                               FontWeight="Bold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding BillToAddress}"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Reference"
                               Style="{StaticResource FieldLabelStyle}" />
                    <TextBlock Text="{Binding Reference}"
                               FontWeight="Bold"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="Workflow"
                               Style="{StaticResource FieldLabelStyle}" />
                    <TextBlock Text="{Binding ApprovalStatus, StringFormat=Approval: {0}}"
                               FontWeight="SemiBold" />
                </StackPanel>

                <StackPanel Grid.Column="6">
                    <TextBlock Text="Documents"
                               Style="{StaticResource FieldLabelStyle}" />
                    <TextBlock Text="{Binding SignedOrderFileName, StringFormat=Signed: {0}}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding InvoiceFileName, StringFormat=Invoice: {0}}"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="16,14,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Order Line Items"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="A read-only view of the saved order."
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{StaticResource CardTintBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10,6"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding Lines.Count, StringFormat={}{0} line items}"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </Border>
                </Grid>

                <DataGrid Grid.Row="1"
                          Margin="14"
                          ItemsSource="{Binding Lines}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Quantity"
                                            Binding="{Binding Quantity, StringFormat={}{0:0}}"
                                            Width="100" />
                        <DataGridTextColumn Header="Part No."
                                            Binding="{Binding PartNumber}"
                                            Width="170" />
                        <DataGridTextColumn Header="Description"
                                            Binding="{Binding Description}"
                                            Width="*" />
                        <DataGridTextColumn Header="Unit Price"
                                            Binding="{Binding UnitPrice, StringFormat=N2}"
                                            Width="140" />
                        <DataGridTextColumn Header="Line Total"
                                            Binding="{Binding LineTotal, StringFormat=N2}"
                                            Width="140" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,10,0,0"
                Style="{StaticResource CardBorderStyle}"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="190" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Signed Order"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding SignedOrderFileName}"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="Upload"
                                Width="92"
                                Height="34"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="OnUploadSignedOrder" />
                        <Button Content="Open"
                                Width="82"
                                Height="34"
                                Margin="8,0,0,0"
                                IsEnabled="{Binding HasSignedOrder}"
                                Click="OnOpenSignedOrder" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="190" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Invoice"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding InvoiceFileName}"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Button Content="Upload"
                                Width="92"
                                Height="34"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="OnUploadInvoice" />
                        <Button Content="Open"
                                Width="82"
                                Height="34"
                                Margin="8,0,0,0"
                                IsEnabled="{Binding HasInvoice}"
                                Click="OnOpenInvoice" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Column="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="130" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Order Maintenance"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource DangerDarkBrush}" />
                        <TextBlock Text="Delete is only available before completion."
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource DangerDarkBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Content="Delete"
                            Width="98"
                            Height="34"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Style="{StaticResource DangerButtonStyle}"
                            IsEnabled="{Binding CanDelete}"
                            Click="OnDeleteOrder" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Margin="0,14,0,0"
                Style="{StaticResource CardBorderStyle}"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button Content="Amend PO"
                            Width="130"
                            Style="{StaticResource PrimaryButtonStyle}"
                            IsEnabled="{Binding CanAmend}"
                            Click="OnAmendOrder" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <Button Content="Close"
                            Width="110"
                            Margin="0,0,10,0"
                            Click="OnCloseWindow" />
                    <Button Content="Export to PDF"
                            Width="140"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="OnExportPdf" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
