<Window x:Class="PurchaseOrderApp.MessageDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        Width="400"
        Height="200"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Message}"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center"
                   Margin="0,0,0,10" />

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="{Binding YesButtonText}"
                    Width="75"
                    Margin="0,0,10,0"
                    Click="OnYesClick"
                    Visibility="{Binding YesButtonVisibility}" />
            <Button Content="{Binding NoButtonText}"
                    Width="75"
                    Margin="0,0,10,0"
                    Click="OnNoClick"
                    Visibility="{Binding NoButtonVisibility}" />
            <Button Content="{Binding OkButtonText}"
                    Width="75"
                    Margin="0,0,10,0"
                    Click="OnOkClick"
                    Visibility="{Binding OkButtonVisibility}" />
            <Button Content="{Binding CancelButtonText}"
                    Width="75"
                    Click="OnCancelClick"
                    Visibility="{Binding CancelButtonVisibility}" />
        </StackPanel>
    </Grid>
</Window>