<Window x:Class="PurchaseOrderApp.JobCardBillingEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Edit Billing"
        Height="860"
        Width="860"
        MinHeight="760"
        MinWidth="760"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="EDIT BILLING"
                               FontSize="28"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding JobCardNumber, StringFormat=Update the installed system and ex VAT pricing for {0}.}"
                               Margin="0,8,0,0"
                               FontSize="14"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Button Grid.Column="1"
                        Width="110"
                        Content="Cancel"
                        Click="OnCancel" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,16,0,16"
                Style="{StaticResource CardBorderStyle}"
                Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="20,18,20,18">
                    <Border Style="{StaticResource CardBorderStyle}"
                            Padding="14"
                            Background="{StaticResource AccentSoftBrush}">
                        <StackPanel>
                            <TextBlock Text="Billing Setup"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="Double-click from the job card details screen now opens this editor. The system type is derived from the extras unless you switch to OTHER."
                                       Margin="0,6,0,12"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap" />

                            <CheckBox Content="Use OTHER as a custom system type"
                                      IsChecked="{Binding UseCustomBillingSystem}"
                                      Margin="0,0,0,8" />

                            <TextBlock Text="Custom System Type"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding CustomBillingSystemName, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,10"
                                     IsEnabled="{Binding UseCustomBillingSystem}" />

                            <Border Background="{StaticResource CardBackgroundBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10,8"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Resolved System Installed"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource SecondaryTextBrush}" />
                                    <TextBlock Text="{Binding BillingSystemTypeDisplay}"
                                               Margin="0,6,0,0"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding BillingSummaryDisplay}"
                                               Margin="0,6,0,0"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="System Price (Ex VAT)"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding SystemPriceExVat, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12" />

                            <CheckBox Content="Panic Button installed"
                                      IsChecked="{Binding HasPanicButton}"
                                      Margin="0,0,0,6" />
                            <TextBlock Text="Panic Button Price (Ex VAT)"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding PanicButtonPriceExVat, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12"
                                     IsEnabled="{Binding HasPanicButton}" />

                            <CheckBox Content="Early Warning System installed"
                                      IsChecked="{Binding HasEarlyWarningSystem}"
                                      Margin="0,0,0,6" />
                            <TextBlock Text="Early Warning System Price (Ex VAT)"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding EarlyWarningSystemPriceExVat, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12"
                                     IsEnabled="{Binding HasEarlyWarningSystem}" />

                            <CheckBox Content="LV CAN adaptor installed"
                                      IsChecked="{Binding HasLvCanAdaptor}"
                                      Margin="0,0,0,6" />
                            <TextBlock Text="LV CAN Adaptor Price (Ex VAT)"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding LvCanAdaptorPriceExVat, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12"
                                     IsEnabled="{Binding HasLvCanAdaptor}" />

                            <TextBlock Text="BLE Sensor Quantity"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding BleSensorQuantity, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8" />

                            <TextBlock Text="BLE Sensor Unit Price (Ex VAT)"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding BleSensorUnitPriceExVat, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12" />

                            <TextBlock Text="Other Hardware Description"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding OtherHardwareDescription, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,8" />

                            <TextBlock Text="Other Hardware Price (Ex VAT)"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding OtherHardwarePriceExVat, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12" />

                            <TextBlock Text="Billing Notes"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding BillingNotes, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,0,12"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="90" />

                            <Border Background="{StaticResource CardBackgroundBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10,8">
                                <StackPanel>
                                    <TextBlock Text="Total Billing"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource SecondaryTextBrush}" />
                                    <TextBlock Text="{Binding BillingTotalExVatDisplay}"
                                               Margin="0,6,0,0"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Save the billing changes here and the job card details screen will refresh immediately."
                           VerticalAlignment="Center"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           TextWrapping="Wrap" />

                <WrapPanel Grid.Column="1"
                           Orientation="Horizontal"
                           VerticalAlignment="Center">
                    <Button Content="Cancel"
                            Width="96"
                            Margin="0,0,12,0"
                            Click="OnCancel" />
                    <Button Content="Save Billing"
                            Width="130"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="OnSave" />
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
