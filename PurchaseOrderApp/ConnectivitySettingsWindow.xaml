<Window x:Class="PurchaseOrderApp.ConnectivitySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Connectivity Settings"
        Height="600"
        Width="980"
        MinHeight="560"
        MinWidth="900"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="88"
                            Height="88"
                            CornerRadius="20"
                            Background="White"
                            BorderBrush="#FFFFFF"
                            BorderThickness="1"
                            Padding="14"
                            Margin="0,0,16,0">
                        <Image Source="Assets/logo.png"
                               Stretch="Uniform" />
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="CONNECTIVITY SETTINGS"
                                   FontSize="28"
                                   FontWeight="Bold" />
                        <TextBlock Text="Manage the saved Wialon and Flickswitch connection details."
                                   Margin="0,8,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Close"
                        Width="120"
                        VerticalAlignment="Top"
                        Click="OnCloseClicked" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,18,0,18"
                Style="{StaticResource CardBorderStyle}">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Wialon"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="These values are used by the Wialon Units and Job Cards windows."
                               Margin="0,8,0,12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />

                    <TextBlock Text="Wialon Host"
                               Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Text="{Binding ApiHost, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"
                             FontFamily="Consolas" />

                    <TextBlock Text="Wialon Access Token"
                               Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Text="{Binding AccessToken, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,0"
                             FontFamily="Consolas"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap" />
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Flickswitch"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="This key is used to resolve the SIM/MSISDN when creating job cards."
                               Margin="0,8,0,12"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />

                    <TextBlock Text="Flickswitch API Key"
                               Style="{StaticResource FieldLabelStyle}" />
                    <TextBox Text="{Binding FlickswitchApiKey, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,12"
                             FontFamily="Consolas"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap" />

                    <Border Background="{StaticResource AccentSoftBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="Saved Status"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Stored securely on this PC using encrypted local storage."
                           VerticalAlignment="Center"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           TextWrapping="Wrap" />

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Save Settings"
                            Width="150"
                            Margin="0,0,12,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="OnSaveClicked" />
                    <Button Content="Close"
                            Width="120"
                            Click="OnCloseClicked" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
