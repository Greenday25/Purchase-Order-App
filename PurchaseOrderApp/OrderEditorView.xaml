<UserControl x:Class="PurchaseOrderApp.OrderEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:PurchaseOrderApp.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="920"
             d:DesignWidth="1180">

    <UserControl.DataContext>
        <vm:MainViewModel />
    </UserControl.DataContext>

    <UserControl.Resources>
        <Style x:Key="LineItemInputStyle" TargetType="TextBox">
            <Setter Property="Margin" Value="4,6" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="KeyboardNavigation.TabNavigation" Value="Continue" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                    <Setter Property="Background" Value="#FBFEFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LineItemNumberInputStyle" TargetType="TextBox" BasedOn="{StaticResource LineItemInputStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Right" />
        </Style>

        <Style x:Key="LineItemTotalTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="4,6" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{StaticResource CardTintBrush}" />
        </Style>

        <Style x:Key="LineItemsGridStyle" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="RowBackground" Value="#FFFFFF" />
            <Setter Property="AlternatingRowBackground" Value="#F8FCFE" />
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="IsTabStop" Value="False" />
                        <Setter Property="KeyboardNavigation.TabNavigation" Value="Continue" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DFF3F8" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="RowStyle">
                <Setter.Value>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Setter Property="MinHeight" Value="54" />
                        <Setter Property="Margin" Value="0,0,0,5" />
                        <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EEF7FA" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#DFF3F8" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroCardStyle}"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Width="58"
                            Height="58"
                            CornerRadius="12"
                            Background="White"
                            BorderBrush="#FFFFFF"
                            BorderThickness="1"
                            Padding="9"
                            Margin="0,0,12,0">
                        <Image Source="Assets/logo.png"
                               Stretch="Uniform" />
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="OFFICIAL ORDER"
                                   FontSize="22"
                                   FontWeight="Bold" />
                        <TextBlock Text="Create a purchase order, prepare the printable layout, then export or print when everything looks right."
                                   Margin="0,4,0,0"
                                   FontSize="12.5"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#FFFFFFCC"
                        BorderBrush="#FFFFFF"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="10,8"
                        VerticalAlignment="Center">
                    <TextBlock Text="Order numbers are generated automatically, but you can edit them before saving."
                               Width="230"
                               FontSize="12.5"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,12,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource CardBorderStyle}"
                    Padding="14"
                    MaxHeight="240">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                        <TextBlock Text="Order Setup"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Set the company, reference, and billing information before adding line items."
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding VatDisplayLabel, StringFormat=Tax: {0}}"
                                   VerticalAlignment="Top"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,12,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                    <WrapPanel ItemHeight="68">
                        <StackPanel Width="180"
                                    Margin="0,0,12,0">
                            <TextBlock Text="Order Number"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding OrderNumber, UpdateSourceTrigger=PropertyChanged}"
                                     IsReadOnly="{Binding IsOrderNumberReadOnly}"
                                     TabIndex="0"
                                     FontSize="13" />
                        </StackPanel>

                        <StackPanel Width="150"
                                    Margin="0,0,12,0">
                            <TextBlock Text="Date"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <DatePicker SelectedDate="{Binding CurrentOrder.Date, UpdateSourceTrigger=PropertyChanged}"
                                        TabIndex="1" />
                        </StackPanel>

                        <StackPanel Width="210"
                                    Margin="0,0,12,0">
                            <TextBlock Text="Reference *"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding CurrentOrder.Reference, UpdateSourceTrigger=PropertyChanged}"
                                     TabIndex="2"
                                     FontSize="13" />
                        </StackPanel>

                        <StackPanel Width="255"
                                    Margin="0,0,12,0">
                            <TextBlock Text="Company"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox ItemsSource="{Binding Vendors}"
                                      SelectedItem="{Binding SelectedVendor}"
                                      DisplayMemberPath="Name"
                                      TabIndex="3"
                                      FontSize="13" />
                        </StackPanel>

                        <StackPanel Width="220"
                                    Margin="0,0,12,0">
                            <TextBlock Text="Manager Approval *"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <ComboBox ItemsSource="{Binding ManagerApprovers}"
                                      SelectedItem="{Binding SelectedManagerApprover}"
                                      DisplayMemberPath="DisplayName"
                                      TabIndex="4"
                                      FontSize="13" />
                        </StackPanel>

                        <StackPanel Width="230"
                                    Margin="0,0,12,0">
                            <TextBlock Text="Bill To *"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Text="{Binding CurrentOrder.BillTo, UpdateSourceTrigger=PropertyChanged}"
                                     TabIndex="5"
                                     FontSize="13" />
                        </StackPanel>

                        <StackPanel Width="360"
                                    Margin="0,0,12,0">
                            <TextBlock Text="Address"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox Height="38"
                                     Text="{Binding CurrentOrder.BillToAddress, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     TabIndex="6"
                                     VerticalContentAlignment="Top"
                                     FontSize="13" />
                        </StackPanel>

                        <Border Width="270"
                                Height="58"
                                Margin="0,0,12,0"
                                Padding="10"
                                Background="{StaticResource CardTintBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                            <StackPanel VerticalAlignment="Center">
                                <CheckBox Content="Include VAT on purchase order"
                                          IsChecked="{Binding CurrentOrder.IncludeVat}"
                                          FontWeight="SemiBold"
                                          TabIndex="7"
                                          Checked="OnIncludeVatChanged"
                                          Unchecked="OnIncludeVatChanged" />
                                <TextBlock Text="{Binding VatDisplayLabel}"
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                </StackPanel>
                        </Border>
                    </WrapPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Line Items"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="Capture the ordered items and let the totals calculate automatically."
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Add Line"
                                Width="120"
                                TabIndex="8"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding AddLineCommand}" />
                    </Grid>

                    <DataGrid Grid.Row="1"
                              Margin="0,20,0,0"
                              ItemsSource="{Binding Lines}"
                              Style="{StaticResource LineItemsGridStyle}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single"
                              RowHeaderWidth="0"
                              TabIndex="9"
                              KeyboardNavigation.TabNavigation="Continue"
                              ColumnHeaderHeight="34">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Quantity" Width="105">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}"
                                                 TabIndex="0"
                                                 Style="{StaticResource LineItemNumberInputStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Part No." Width="145">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding PartNumber, UpdateSourceTrigger=PropertyChanged}"
                                                 TabIndex="1"
                                                 Style="{StaticResource LineItemInputStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Description" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                 TabIndex="2"
                                                 Style="{StaticResource LineItemInputStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Unit Price" Width="125">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding UnitPriceText, UpdateSourceTrigger=PropertyChanged}"
                                                 TabIndex="3"
                                                 Style="{StaticResource LineItemNumberInputStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Line Total" Width="125" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LineTotalDisplay}"
                                                   Style="{StaticResource LineItemTotalTextStyle}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Action" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Remove"
                                                Width="86"
                                                Height="34"
                                                Margin="4,6"
                                                TabIndex="4"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2"
                            Margin="0,18,0,0"
                            Padding="12,10"
                            Background="{StaticResource CardTintBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Calculated Totals"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="Totals update as you edit line quantities and prices."
                                           Margin="0,4,0,0"
                                           Foreground="{StaticResource SecondaryTextBrush}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <StackPanel Margin="0,0,24,0">
                                    <TextBlock Text="Subtotal" />
                                    <TextBlock Text="{Binding VatDisplayLabel}" Margin="0,8,0,0" />
                                    <TextBlock Text="Total" Margin="0,8,0,0" FontWeight="Bold" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="{Binding SubTotal, StringFormat=R {0:N2}}" TextAlignment="Right" />
                                    <TextBlock Text="{Binding VatAmount, StringFormat=R {0:N2}}" Margin="0,8,0,0" TextAlignment="Right" />
                                    <TextBlock Text="{Binding TotalAmount, StringFormat=R {0:N2}}" Margin="0,8,0,0" FontWeight="Bold" TextAlignment="Right" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Close"
                        Width="110"
                        Margin="0,0,10,0"
                        TabIndex="20"
                        Click="OnCloseWindow" />
                <Button Content="Export to PDF"
                        Width="130"
                        Margin="0,0,10,0"
                        TabIndex="21"
                        Click="OnExportPdf" />
                <Button Content="Save PO"
                        Width="120"
                        TabIndex="22"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="OnSavePurchaseOrder" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

