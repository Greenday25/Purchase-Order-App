<Window x:Class="PurchaseOrderApp.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Capital Air (Pty) Ltd"
        Height="720"
        Width="1120"
        MinHeight="640"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <Style x:Key="TileButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Height" Value="176" />
            <Setter Property="MinHeight" Value="176" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.93" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.84" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroCardStyle}"
                Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Width="58"
                            Height="58"
                            CornerRadius="12"
                            Background="White"
                            BorderBrush="#FFFFFF"
                            BorderThickness="1"
                            Padding="9"
                            Margin="0,0,12,0">
                        <Image Source="Assets/logo.png"
                               Stretch="Uniform" />
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="CAPITAL AIR (PTY) LTD"
                                   FontSize="22"
                                   FontWeight="Bold" />
                        <TextBlock Text="Choose a workspace to continue."
                                   Margin="0,4,0,0"
                                   FontSize="12.5"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#FFFFFFCC"
                        BorderBrush="#FFFFFF"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Workspace Menu"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" />
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,5,0,0">
                                <TextBlock Text="{Binding SelectedUser.DisplayName}"
                                           FontSize="14"
                                           FontWeight="Bold" />
                                <TextBlock Text="  |  "
                                           FontSize="12"
                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding CurrentRoleName}"
                                           FontSize="12"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                            <TextBlock Text="{Binding CurrentAccessSummary}"
                                       Margin="0,3,0,0"
                                       FontSize="11.5"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       Width="280" />
                        </StackPanel>

                        <Grid Grid.Column="2"
                              VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <Button Content="Manage Users &amp; Roles"
                                        Width="170"
                                        Height="30"
                                        Margin="0,0,8,0"
                                        Padding="10,5"
                                        IsEnabled="{Binding CanManageUsers}"
                                        Visibility="{Binding CanManageUsers, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Click="OnOpenUserManagement" />
                                <Button Content="Logout"
                                        Width="96"
                                        Height="30"
                                        Padding="10,5"
                                        Click="OnLogout" />
                            </StackPanel>

                            <Button Grid.Row="1"
                                    Content="Connectivity Settings"
                                    Width="200"
                                    Height="30"
                                    Margin="0,8,0,0"
                                    Padding="10,5"
                                    HorizontalAlignment="Right"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    IsEnabled="{Binding CanAccessConnectivitySettings}"
                                    Visibility="{Binding CanAccessConnectivitySettings, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Click="OnOpenConnectivitySettings" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

            <Grid Grid.Row="1"
                  Margin="0,14,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
            <Button Style="{StaticResource TileButtonStyle}"
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="0,0,12,12"
                    IsEnabled="{Binding CanAccessPurchaseOrders}"
                    Visibility="{Binding CanAccessPurchaseOrders, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Click="OnOpenPurchaseOrders">
                <Border Background="{StaticResource AccentBrush}"
                        CornerRadius="12"
                        Padding="18"
                        BorderBrush="{StaticResource AccentDarkBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <Border Width="40"
                                    Height="40"
                                    CornerRadius="12"
                                    Background="#FFFFFF26"
                                    BorderBrush="#FFFFFF33"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock Text="PO"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Margin="12,0,0,0">
                                <TextBlock Text="Purchase Orders"
                                           Foreground="White"
                                           FontSize="22"
                                           FontWeight="Bold" />
                                <TextBlock Text="Create, approve, print, export, and archive orders"
                                           Foreground="#E7F6FA"
                                           Margin="0,4,0,0"
                                           FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Text="Manage active orders, approvals, invoices, and archived PDFs from one purchase order workspace."
                                   Foreground="White"
                                   Margin="0,14,0,0"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />

                        <Border Grid.Row="2"
                                Margin="0,14,0,0"
                                Background="#FFFFFF1A"
                                CornerRadius="9"
                                Padding="10,6"
                                HorizontalAlignment="Left">
                            <TextBlock Text="Open module"
                                       Foreground="White"
                                       FontWeight="SemiBold" />
                        </Border>
                    </Grid>
                </Border>
            </Button>

            <Button Style="{StaticResource TileButtonStyle}"
                    Grid.Row="0"
                    Grid.Column="1"
                    Margin="12,0,0,12"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    IsEnabled="{Binding CanAccessWialonUnits}"
                    Visibility="{Binding CanAccessWialonUnits, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Click="OnOpenWialonUnits">
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="18"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <Border Width="40"
                                    Height="40"
                                    CornerRadius="12"
                                    Background="{StaticResource AccentSoftBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock Text="WU"
                                           Foreground="{StaticResource AccentDarkBrush}"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Margin="12,0,0,0">
                                <TextBlock Text="Wialon Units"
                                           FontSize="22"
                                           FontWeight="Bold" />
                                <TextBlock Text="Load live units from Wialon"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,4,0,0"
                                           FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Text="Fetch available Wialon units, review key details, and stage them for the next job card workflow step."
                                   Margin="0,14,0,0"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />

                        <Border Grid.Row="2"
                                Margin="0,14,0,0"
                                Background="{StaticResource AccentSoftBrush}"
                                CornerRadius="9"
                                Padding="10,6"
                                HorizontalAlignment="Left">
                            <TextBlock Text="Open module"
                                       Foreground="{StaticResource AccentDarkBrush}"
                                       FontWeight="SemiBold" />
                        </Border>
                    </Grid>
                </Border>
            </Button>

            <Button Style="{StaticResource TileButtonStyle}"
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,12,12,0"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    IsEnabled="{Binding CanAccessJobCards}"
                    Visibility="{Binding CanAccessJobCards, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Click="OnOpenJobCards">
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="18"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <Border Width="40"
                                    Height="40"
                                    CornerRadius="12"
                                    Background="{StaticResource AccentSoftBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock Text="JC"
                                           Foreground="{StaticResource AccentDarkBrush}"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Margin="12,0,0,0">
                                <TextBlock Text="Job Cards"
                                           FontSize="22"
                                           FontWeight="Bold" />
                                <TextBlock Text="Create Wialon units from a job card"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,4,0,0"
                                           FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Text="Capture vehicle details, resolve SIM data through Flickswitch, and create linked Wialon units from each job card."
                                   Margin="0,14,0,0"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />

                        <Border Grid.Row="2"
                                Margin="0,14,0,0"
                                Background="{StaticResource AccentSoftBrush}"
                                CornerRadius="9"
                                Padding="10,6"
                                HorizontalAlignment="Left">
                            <TextBlock Text="Open module"
                                       Foreground="{StaticResource AccentDarkBrush}"
                                       FontWeight="SemiBold" />
                        </Border>
                    </Grid>
                </Border>
            </Button>

            <Button Style="{StaticResource TileButtonStyle}"
                    Grid.Row="1"
                    Grid.Column="1"
                    Margin="12,12,0,0"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    IsEnabled="{Binding CanAccessTrackingCertificates}"
                    Visibility="{Binding CanAccessTrackingCertificates, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Click="OnOpenTrackingCertificates">
                <Border Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="12"
                        Padding="18"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <Border Width="40"
                                    Height="40"
                                    CornerRadius="12"
                                    Background="#FFF7D6"
                                    BorderBrush="#F3D77C"
                                    BorderThickness="1"
                                    VerticalAlignment="Center">
                                <TextBlock Text="TC"
                                           Foreground="#7A5A00"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>

                            <StackPanel Margin="12,0,0,0">
                                <TextBlock Text="Tracking Certificates"
                                           FontSize="22"
                                           FontWeight="Bold" />
                                <TextBlock Text="Build certificate PDFs from Wialon data"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,4,0,0"
                                           FontSize="12" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Grid.Row="1"
                                   Text="Load Wialon units, select the correct vehicle, and export installation certificates in the Capital Air format."
                                   Margin="0,14,0,0"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />

                        <Border Grid.Row="2"
                                Margin="0,14,0,0"
                                Background="#FFF7D6"
                                CornerRadius="9"
                                Padding="10,6"
                                HorizontalAlignment="Left">
                            <TextBlock Text="Open module"
                                       Foreground="#7A5A00"
                                       FontWeight="SemiBold" />
                        </Border>
                    </Grid>
                </Border>
            </Button>

                <Button Style="{StaticResource TileButtonStyle}"
                        Grid.Row="2"
                        Grid.Column="0"
                        Margin="0,12,12,0"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        IsEnabled="{Binding CanAccessInventory}"
                        Visibility="{Binding CanAccessInventory, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Click="OnOpenInventory">
                    <Border Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="12"
                            Padding="18"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Orientation="Horizontal">
                                <Border Width="40"
                                        Height="40"
                                        CornerRadius="12"
                                        Background="#E8F5EA"
                                        BorderBrush="#BCDCC4"
                                        BorderThickness="1"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="SI"
                                               Foreground="#255D30"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>

                                <StackPanel Margin="12,0,0,0">
                                    <TextBlock Text="Stock Inventory"
                                               FontSize="22"
                                               FontWeight="Bold" />
                                    <TextBlock Text="Receive and issue stock with job card links"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Margin="0,4,0,0"
                                               FontSize="12" />
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Grid.Row="1"
                                       Text="Open the inventory workspace to receive stock, issue stock, and force tracking unit issues to point at a specific job card."
                                       Margin="0,14,0,0"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />

                            <Border Grid.Row="2"
                                    Margin="0,14,0,0"
                                    Background="#E8F5EA"
                                    CornerRadius="9"
                                    Padding="10,6"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="Open module"
                                           Foreground="#255D30"
                                           FontWeight="SemiBold" />
                            </Border>
                        </Grid>
                    </Border>
                </Button>

                <Border Grid.Row="2"
                        Grid.Column="1"
                        Height="176"
                        Margin="12,12,0,0"
                        CornerRadius="12"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        Background="{StaticResource CardBackgroundBrush}"
                        Visibility="{Binding CanAccessInventory, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>

            <TextBlock Grid.Row="2"
                       Text="Completed orders are archived automatically when the signed order and invoice are present."
                       Foreground="{StaticResource SecondaryTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6" />
        </Grid>
    </ScrollViewer>
</Window>
