<Window x:Class="PurchaseOrderApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PurchaseOrderApp.ViewModels"
        mc:Ignorable="d"
        Title="Purchase Order Dashboard"
        Height="820"
        Width="1400"
        MinHeight="760"
        MinWidth="1200">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="112"
                            Height="112"
                            CornerRadius="22"
                            Background="White"
                            BorderBrush="#FFFFFF"
                            BorderThickness="1"
                            Padding="16"
                            Margin="0,0,18,0">
                        <Image Source="Assets/logo.png"
                               Stretch="Uniform" />
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="PURCHASE ORDER HISTORY"
                                   FontSize="30"
                                   FontWeight="Bold" />
                        <TextBlock Text="Track approvals, signed orders, invoices, and company-specific order sequences from one dashboard."
                                   Margin="0,8,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Button Content="Refresh History"
                            Width="150"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding RefreshHistoryCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,20,0,18"
                Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="370" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Search Orders"
                                   Style="{StaticResource SectionTitleStyle}"
                                   FontSize="18"
                                   VerticalAlignment="Center" />

                        <Button Grid.Column="1"
                                Content="New Order"
                                Width="132"
                                Margin="12,0,0,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="OnNewOrder" />
                    </Grid>

                    <TextBlock Text="Search by order number, supplier, status, company, or reference."
                               Margin="0,0,0,10"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />

                    <TextBox Text="{Binding HistorySearchText, UpdateSourceTrigger=PropertyChanged}"
                             Height="40"
                             VerticalContentAlignment="Center"
                             FontSize="14" />
                </StackPanel>

                <Border Grid.Column="2"
                        Background="{StaticResource CardTintBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="18">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Workflow Tip"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}" />
                        <TextBlock Text="Double-click any order to open its full workflow, upload signed documents and invoices, export the PDF, or delete it before completion."
                                   Margin="0,8,0,0"
                                   FontSize="14"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="20,18,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Order History"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Open any order to manage approvals, supporting documents, and PDF exports."
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{StaticResource CardTintBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,8"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding FilteredOrderHistory.Count, StringFormat={}{0} orders visible}"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </Border>
                </Grid>

                <DataGrid Grid.Row="1"
                          Margin="16,18,16,16"
                          ItemsSource="{Binding FilteredOrderHistory}"
                          SelectedItem="{Binding SelectedOrderHistoryItem}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          MouseDoubleClick="OnHistoryRowDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Order #" Binding="{Binding OrderNumber}" Width="140" />
                        <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=dd/MM/yyyy}" Width="120" />
                        <DataGridTextColumn Header="Company" Binding="{Binding CompanyName}" Width="300" />
                        <DataGridTextColumn Header="Bill To" Binding="{Binding BillTo}" Width="220" />
                        <DataGridTextColumn Header="Reference" Binding="{Binding Reference}" Width="*" />
                        <DataGridTextColumn Header="Status" Binding="{Binding OrderStatus}" Width="170" />
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat=R {0:N2}}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>
