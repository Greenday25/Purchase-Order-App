<Window x:Class="PurchaseOrderApp.OrderEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:PurchaseOrderApp.ViewModels"
        mc:Ignorable="d"
        Title="New Order"
        Height="920"
        Width="1180"
        MinHeight="820"
        MinWidth="1040"
        WindowStartupLocation="CenterOwner">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="96"
                            Height="96"
                            CornerRadius="20"
                            Background="White"
                            BorderBrush="#FFFFFF"
                            BorderThickness="1"
                            Padding="14"
                            Margin="0,0,18,0">
                        <Image Source="Assets/logo.png"
                               Stretch="Uniform" />
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="OFFICIAL ORDER"
                                   FontSize="30"
                                   FontWeight="Bold" />
                        <TextBlock Text="Create a purchase order, prepare the printable layout, then export or print when everything looks right."
                                   Margin="0,8,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#FFFFFFCC"
                        BorderBrush="#FFFFFF"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14,10"
                        VerticalAlignment="Top">
                    <TextBlock Text="Order numbers are generated automatically from the selected company."
                               Width="250"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,20,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Order Setup"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Set the company, reference, and billing information before adding line items."
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Margin="0,22,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Order Number"
                                   Style="{StaticResource FieldLabelStyle}" />
                        <TextBox Grid.Row="0"
                                 Margin="0,24,0,0"
                                 Text="{Binding CurrentOrder.OrderNumber, UpdateSourceTrigger=PropertyChanged}"
                                 IsReadOnly="True"
                                 FontSize="14" />

                        <TextBlock Grid.Row="1"
                                   Text="Date"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Margin="0,18,0,6" />
                        <DatePicker Grid.Row="1"
                                    Margin="0,42,0,0"
                                    SelectedDate="{Binding CurrentOrder.Date, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2"
                                   Text="Reference"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Margin="0,18,0,6" />
                        <TextBox Grid.Row="2"
                                 Margin="0,42,0,0"
                                 Text="{Binding CurrentOrder.Reference, UpdateSourceTrigger=PropertyChanged}"
                                 TextChanged="OnReferenceChanged"
                                 FontSize="14" />

                        <TextBlock Grid.Row="3"
                                   Text="Company"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Margin="0,18,0,6" />
                        <ComboBox Grid.Row="3"
                                  Margin="0,42,0,0"
                                  ItemsSource="{Binding Vendors}"
                                  SelectedItem="{Binding SelectedVendor}"
                                  DisplayMemberPath="Name"
                                  FontSize="14" />

                        <TextBlock Grid.Row="4"
                                   Text="Bill To"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Margin="0,18,0,6" />
                        <TextBox Grid.Row="4"
                                 Margin="0,42,0,0"
                                 Text="{Binding CurrentOrder.BillTo, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14" />

                        <TextBlock Grid.Row="5"
                                   Text="Address"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Margin="0,18,0,6" />
                        <TextBox Grid.Row="5"
                                 Margin="0,42,0,0"
                                 Height="84"
                                 Text="{Binding CurrentOrder.BillToAddress, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalContentAlignment="Top"
                                 FontSize="14" />

                        <TextBlock Grid.Row="6"
                                   Text="Tax on This Order"
                                   Style="{StaticResource FieldLabelStyle}"
                                   Margin="0,18,0,6" />
                        <Border Grid.Row="6"
                                Margin="0,42,0,0"
                                Padding="14"
                                Background="{StaticResource CardTintBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel>
                                <CheckBox Content="Include VAT on the purchase order"
                                          IsChecked="{Binding CurrentOrder.IncludeVat}"
                                          FontWeight="SemiBold"
                                          Checked="OnIncludeVatChanged"
                                          Unchecked="OnIncludeVatChanged" />
                                <TextBlock Text="{Binding VatDisplayLabel}"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource SecondaryTextBrush}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="7"
                                Margin="0,24,0,0"
                                Padding="16"
                                Background="{StaticResource AccentSoftBrush}"
                                BorderBrush="#C9E7EF"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel>
                                <TextBlock Text="Quick Tip"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Text="Use the company selector to switch prefixes, adjust VAT only when the supplier needs it shown, then add the line items before saving or exporting."
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Line Items"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="Capture the ordered items and let the totals calculate automatically."
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Add Line"
                                Width="120"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding AddLineCommand}" />
                    </Grid>

                    <DataGrid Grid.Row="1"
                              Margin="0,20,0,0"
                              ItemsSource="{Binding Lines}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity, StringFormat={}{0:0}, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                            <DataGridTextColumn Header="Part No." Binding="{Binding PartNumber, UpdateSourceTrigger=PropertyChanged}" Width="130" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                            <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" Width="110" />
                            <DataGridTextColumn Header="Line Total" Binding="{Binding LineTotal, StringFormat=N2}" Width="110" IsReadOnly="True" />
                            <DataGridTemplateColumn Header="Action" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Remove"
                                                Margin="4,2"
                                                Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2"
                            Margin="0,18,0,0"
                            Padding="18"
                            Background="{StaticResource CardTintBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Calculated Totals"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="The purchase order updates instantly as you edit quantities and prices."
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right">
                                <StackPanel Margin="0,0,24,0">
                                    <TextBlock Text="Subtotal" />
                                    <TextBlock Text="{Binding VatDisplayLabel}" Margin="0,8,0,0" />
                                    <TextBlock Text="Total" Margin="0,8,0,0" FontWeight="Bold" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="{Binding SubTotal, StringFormat=R {0:N2}}" TextAlignment="Right" />
                                    <TextBlock Text="{Binding VatAmount, StringFormat=R {0:N2}}" Margin="0,8,0,0" TextAlignment="Right" />
                                    <TextBlock Text="{Binding TotalAmount, StringFormat=R {0:N2}}" Margin="0,8,0,0" FontWeight="Bold" TextAlignment="Right" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Close"
                        Width="110"
                        Margin="0,0,10,0"
                        Click="OnCloseWindow" />
                <Button Content="Print Invoice"
                        Width="130"
                        Margin="0,0,10,0"
                        Click="OnPrintInvoice" />
                <Button Content="Export to PDF"
                        Width="130"
                        Margin="0,0,10,0"
                        Click="OnExportPdf" />
                <Button Content="Save PO"
                        Width="120"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding SavePurchaseOrderCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
