<Window x:Class="PurchaseOrderApp.InventoryMovementsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Recent Stock Movements"
        Height="920"
        Width="1460"
        MinHeight="820"
        MinWidth="1220"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="96"
                            Height="96"
                            CornerRadius="22"
                            Background="White"
                            BorderBrush="#FFFFFF"
                            BorderThickness="1"
                            Padding="16"
                            Margin="0,0,18,0">
                        <Image Source="Assets/logo.png"
                               Stretch="Uniform" />
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="RECENT STOCK MOVEMENTS"
                                   FontSize="30"
                                   FontWeight="Bold" />
                        <TextBlock Text="Review the full stock ledger, including tracking-unit issues linked back to job cards."
                                   Margin="0,8,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           Orientation="Horizontal"
                           VerticalAlignment="Top">
                    <Button Content="Back to Inventory"
                            Width="150"
                            Margin="0,0,12,0"
                            Click="OnCloseWindow" />
                    <Button Content="Refresh"
                            Width="110"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding RefreshHistoryCommand}" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,18,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="14,12">
                <StackPanel>
                    <TextBlock Text="ENTRIES"
                               Style="{StaticResource FieldLabelStyle}" />
                    <TextBlock Text="{Binding TotalTransactionCount, StringFormat={}{0} total}"
                               Margin="0,6,0,0"
                               FontSize="20"
                               FontWeight="Bold" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="14,12">
                <StackPanel>
                    <TextBlock Text="VISIBLE"
                               Style="{StaticResource FieldLabelStyle}" />
                    <TextBlock Text="{Binding VisibleTransactionCount, StringFormat={}{0} shown}"
                               Margin="0,6,0,0"
                               FontSize="20"
                               FontWeight="Bold" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="14,12">
                <StackPanel>
                    <TextBlock Text="LINKED JOB CARDS"
                               Style="{StaticResource FieldLabelStyle}" />
                    <TextBlock Text="{Binding LinkedJobCardCount, StringFormat={}{0} linked}"
                               Margin="0,6,0,0"
                               FontSize="20"
                               FontWeight="Bold" />
                </StackPanel>
            </Border>

            <Border Grid.Column="6"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="14,12"
                    Background="{StaticResource AccentSoftBrush}">
                <StackPanel>
                    <TextBlock Text="STOCK OUT"
                               Style="{StaticResource FieldLabelStyle}" />
                    <TextBlock Text="{Binding StockOutCount, StringFormat={}{0} issue entries}"
                               Margin="0,6,0,0"
                               FontSize="20"
                               FontWeight="Bold" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="20,18,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="240" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Movement History"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Search by date, type, item, job card, or notes."
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <TextBox Grid.Column="1"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Height="38"
                             VerticalContentAlignment="Center"
                             FontSize="13.5" />
                </Grid>

                <DataGrid Grid.Row="1"
                          Margin="16,0,16,16"
                          ItemsSource="{Binding FilteredTransactions}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date"
                                            Binding="{Binding CreatedAtDisplay}"
                                            Width="150" />
                        <DataGridTextColumn Header="Type"
                                            Binding="{Binding TransactionType}"
                                            Width="110" />
                        <DataGridTextColumn Header="Issue #"
                                            Binding="{Binding IssueOutNumberDisplay}"
                                            Width="110" />
                        <DataGridTextColumn Header="Item"
                                            Binding="{Binding ItemDisplay}"
                                            Width="1.8*" />
                        <DataGridTextColumn Header="Qty"
                                            Binding="{Binding QuantityDisplay}"
                                            Width="90" />
                        <DataGridTextColumn Header="Balance"
                                            Binding="{Binding QuantityAfterTransaction}"
                                            Width="90" />
                        <DataGridTextColumn Header="Job Card"
                                            Binding="{Binding JobCardDisplay}"
                                            Width="140" />
                        <DataGridTextColumn Header="Notes"
                                            Binding="{Binding Notes}"
                                            Width="1.5*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,16,0,0"
                Style="{StaticResource CardBorderStyle}"
                Padding="16,12">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
