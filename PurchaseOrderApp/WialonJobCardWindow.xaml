<Window x:Class="PurchaseOrderApp.WialonJobCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Job Card Register"
        Height="960"
        Width="1480"
        MinHeight="860"
        MinWidth="1280"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="96"
                                Height="96"
                                CornerRadius="22"
                                Background="White"
                                BorderBrush="#FFFFFF"
                                BorderThickness="1"
                                Padding="16"
                                Margin="0,0,18,0">
                            <Image Source="Assets/logo.png"
                                   Stretch="Uniform" />
                        </Border>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="JOB CARD REGISTER"
                                       FontSize="30"
                                       FontWeight="Bold" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       Margin="0,8,0,0"
                                       FontSize="14"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>

                    <Grid Margin="114,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="White"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="NEXT JOB CARD"
                                           FontSize="11.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding NextJobCardNumber}"
                                           Margin="0,4,0,0"
                                           FontFamily="Consolas"
                                           FontWeight="Bold" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Background="White"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="RECORDED"
                                           FontSize="11.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding JobCardHistory.Count, StringFormat={}{0} job card(s)}"
                                           Margin="0,4,0,0"
                                           FontWeight="Bold" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4"
                                Background="White"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="CONNECTED AS"
                                           FontSize="11.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding CurrentCreatorDisplay}"
                                           Margin="0,4,0,0"
                                           FontWeight="Bold"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="6"
                                Background="White"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12,8">
                            <StackPanel>
                                <TextBlock Text="EXISTING WIALON UNITS"
                                           FontSize="11.5"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding ExistingWialonUnits.Count, StringFormat={}{0} loaded}"
                                           Margin="0,4,0,0"
                                           FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           Orientation="Horizontal"
                           VerticalAlignment="Top">
                    <Button Content="New Job Card"
                            Width="140"
                            Margin="0,0,12,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="OnOpenEditorWindow" />
                    <Button Content="Historical Register"
                            Width="160"
                            Margin="0,0,12,0"
                            Click="OnOpenHistoricalWindow" />
                    <Button Content="Load Wialon Setup"
                            Width="150"
                            Margin="0,0,12,0"
                            Command="{Binding LoadWialonSetupCommand}" />
                    <Button Content="Back to Menu"
                            Width="120"
                            Click="OnCloseWindow" />
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,16,0,16"
                Style="{StaticResource CardBorderStyle}"
                Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource CardTintBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14,12">
                    <TextBlock Text="The register now stays visible while the detailed create and historical flows open in their own windows."
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <Border Grid.Column="2"
                        Background="{StaticResource AccentSoftBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14,12">
                    <TextBlock Text="Use New Job Card for fresh Wialon units, or Historical Register for older physical job cards where the unit already exists."
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                </Border>

                <Border Grid.Column="4"
                        Background="{StaticResource CardTintBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="14,12">
                    <TextBlock Text="{Binding CreatedJobCardNumber, StringFormat=Latest recorded job card: {0}}"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}"
                Padding="18,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Job Card Register"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="This table is the main workspace now, so you can keep the registry in view while the detailed capture screens open separately. Double-click a job card to manage installation photos or export its PDF."
                               Margin="0,6,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           Orientation="Horizontal"
                           VerticalAlignment="Top">
                    <Button Content="New Job Card"
                            Width="140"
                            Margin="0,0,12,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="OnOpenEditorWindow" />
                    <Button Content="Historical Register"
                            Width="160"
                            Click="OnOpenHistoricalWindow" />
                </WrapPanel>

                <DataGrid Grid.Row="1"
                          Grid.ColumnSpan="2"
                          Margin="0,16,0,0"
                          ItemsSource="{Binding JobCardHistory}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionUnit="FullRow"
                          MouseDoubleClick="OnJobCardDoubleClick"
                          EnableRowVirtualization="True"
                          EnableColumnVirtualization="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Job Card"
                                            Binding="{Binding JobCardNumber}"
                                            Width="130" />
                        <DataGridTextColumn Header="Created"
                                            Binding="{Binding CreatedAtDisplay}"
                                            Width="150" />
                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding WorkflowStatus}"
                                            Width="190" />
                        <DataGridTextColumn Header="Vehicle"
                                            Binding="{Binding VehicleDisplay}"
                                            Width="190" />
                        <DataGridTextColumn Header="Client"
                                            Binding="{Binding Client}"
                                            Width="1.2*" />
                        <DataGridTextColumn Header="Wialon Unit"
                                            Binding="{Binding UnitDisplay}"
                                            Width="1.3*" />
                        <DataGridTextColumn Header="Notes"
                                            Binding="{Binding StatusNotes}"
                                            Width="1.7*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,16,0,0"
                Style="{StaticResource CardBorderStyle}"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                    <WrapPanel Margin="0,8,0,0"
                               Orientation="Horizontal">
                        <TextBlock Text="{Binding CreatedJobCardNumber, StringFormat=Recorded job card: {0}}"
                                   Margin="0,0,18,0"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBlock Text="{Binding CreatedUnitName, StringFormat=Created unit name: {0}}"
                                   Margin="0,0,18,0"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBlock Text="{Binding CreatedUnitId, StringFormat=Created unit ID: {0}}"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </WrapPanel>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="{Binding NextJobCardNumber, StringFormat=Next sequence: {0}}"
                           FontFamily="Consolas"
                           FontWeight="Bold"
                           Foreground="{StaticResource SecondaryTextBrush}" />
            </Grid>
        </Border>
    </Grid>
</Window>
