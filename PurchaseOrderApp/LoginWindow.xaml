<Window x:Class="PurchaseOrderApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Capital Air Login"
        Height="520"
        Width="820"
        MinHeight="500"
        MinWidth="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Grid Margin="26">
        <Border Style="{StaticResource HeroCardStyle}"
                Padding="28">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="340" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <Border Width="118"
                            Height="118"
                            CornerRadius="24"
                            Background="White"
                            Padding="18"
                            HorizontalAlignment="Left">
                        <Image Source="Assets/logo.png"
                               Stretch="Uniform" />
                    </Border>

                    <TextBlock Text="CAPITAL AIR"
                               Margin="0,24,0,0"
                               FontSize="34"
                               FontWeight="Bold" />
                    <TextBlock Text="Sign in to continue to your assigned workspace."
                               Margin="0,10,40,0"
                               FontSize="15"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="22"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Login"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="Use your local app user account."
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Margin="0,22,0,0">
                            <TextBlock Text="User Name"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="UserNameTextBox"
                                     Height="40"
                                     VerticalContentAlignment="Center" />
                        </StackPanel>

                        <StackPanel Grid.Row="2"
                                    Margin="0,14,0,0">
                            <TextBlock Text="Password"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <PasswordBox x:Name="PasswordBox"
                                         Height="40"
                                         Padding="10,7"
                                         KeyDown="OnPasswordKeyDown" />
                        </StackPanel>

                        <TextBlock x:Name="StatusTextBlock"
                                   Grid.Row="3"
                                   Margin="0,12,0,0"
                                   Foreground="{StaticResource DangerDarkBrush}"
                                   TextWrapping="Wrap" />

                        <Grid Grid.Row="4"
                              Margin="0,22,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button Content="Exit"
                                    Width="100"
                                    Click="OnExit" />
                            <Button Grid.Column="1"
                                    Content="Login"
                                    Width="130"
                                    IsDefault="True"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="OnLogin" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
