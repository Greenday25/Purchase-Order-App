<Window x:Class="PurchaseOrderApp.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Access"
        Height="720"
        Width="1180"
        MinHeight="640"
        MinWidth="1040"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="82"
                        Height="82"
                        CornerRadius="18"
                        Background="White"
                        Padding="13"
                        Margin="0,0,16,0">
                    <Image Source="Assets/logo.png"
                           Stretch="Uniform" />
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                    <TextBlock Text="USER ACCESS"
                               FontSize="28"
                               FontWeight="Bold" />
                    <TextBlock Text="Create users and assign roles that control which home screen workspaces can be opened."
                               Margin="0,7,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}" />
                </StackPanel>

                <Border Grid.Column="2"
                        Background="#FFFFFFCC"
                        BorderBrush="#FFFFFF"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="14,12"
                        VerticalAlignment="Center">
                    <TextBlock Text="Access changes take effect as soon as this window closes."
                               Width="230"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource SecondaryTextBrush}" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,20,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Users"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="Create a local app user and assign one of the roles."
                                   Margin="0,7,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,16,0,16"
                            Background="{StaticResource CardTintBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Text="User Name"
                                       Style="{StaticResource FieldLabelStyle}" />
                            <TextBox x:Name="UserNameTextBox"
                                     Grid.Row="1" />

                            <Grid Grid.Row="2"
                                  Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Role"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <ComboBox x:Name="UserRoleComboBox"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="AppRoleId" />
                                </StackPanel>

                                <CheckBox x:Name="UserActiveCheckBox"
                                          Grid.Column="1"
                                          Content="Active"
                                          Margin="16,26,0,0"
                                          IsChecked="True"
                                          VerticalAlignment="Top" />
                            </Grid>

                            <Grid Grid.Row="3"
                                  Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Password"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <PasswordBox x:Name="UserPasswordBox"
                                                 Height="36"
                                                 Padding="10,7" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Confirm"
                                               Style="{StaticResource FieldLabelStyle}" />
                                    <PasswordBox x:Name="UserConfirmPasswordBox"
                                                 Height="36"
                                                 Padding="10,7" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Grid.Row="4"
                                       Text="Leave password blank when updating a user to keep the existing password."
                                       Margin="0,8,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}" />

                            <StackPanel Grid.Row="5"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,14,0,0">
                                <Button Content="New"
                                        Width="90"
                                        Click="OnNewUser" />
                                <Button Content="Save User"
                                        Width="120"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="OnSaveUser" />
                                <Button Content="Delete"
                                        Width="90"
                                        Margin="10,0,0,0"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Click="OnDeleteUser" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="UsersGrid"
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              SelectionChanged="OnSelectedUserChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="User" Binding="{Binding DisplayName}" Width="*" />
                            <DataGridTextColumn Header="Role" Binding="{Binding Role.Name}" Width="150" />
                            <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Roles"
                                       Style="{StaticResource SectionTitleStyle}" />
                            <TextBlock Text="Tick the modules each role can open from the home screen."
                                       Margin="0,7,0,0"
                                       Foreground="{StaticResource SecondaryTextBrush}" />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Save Role Changes"
                                Width="170"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="OnSaveRoles" />
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,16,0,16"
                            Background="{StaticResource CardTintBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="New Role Name"
                                           Style="{StaticResource FieldLabelStyle}" />
                                <TextBox x:Name="RoleNameTextBox" />
                            </StackPanel>

                            <WrapPanel Grid.Column="1"
                                       Margin="16,20,16,0">
                                <CheckBox x:Name="RolePurchaseOrdersCheckBox" Content="Purchase Orders" Margin="0,0,14,8" />
                                <CheckBox x:Name="RoleJobCardsCheckBox" Content="Job Cards" Margin="0,0,14,8" />
                                <CheckBox x:Name="RoleWialonUnitsCheckBox" Content="Wialon Units" Margin="0,0,14,8" />
                                <CheckBox x:Name="RoleTrackingCertificatesCheckBox" Content="Tracking Certificates" Margin="0,0,14,8" />
                                <CheckBox x:Name="RoleInventoryCheckBox" Content="Inventory" Margin="0,0,14,8" />
                                <CheckBox x:Name="RoleConnectivityCheckBox" Content="Connectivity Settings" Margin="0,0,14,8" />
                                <CheckBox x:Name="RoleManageUsersCheckBox" Content="Manage Users" Margin="0,0,14,8" />
                            </WrapPanel>

                            <Button Grid.Column="2"
                                    Content="Add Role"
                                    Width="110"
                                    VerticalAlignment="Bottom"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="OnAddRole" />
                        </Grid>
                    </Border>

                    <DataGrid x:Name="RolesGrid"
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Role" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="180" />
                            <DataGridCheckBoxColumn Header="PO" Binding="{Binding CanAccessPurchaseOrders}" Width="60" />
                            <DataGridCheckBoxColumn Header="Jobs" Binding="{Binding CanAccessJobCards}" Width="70" />
                            <DataGridCheckBoxColumn Header="Wialon" Binding="{Binding CanAccessWialonUnits}" Width="80" />
                            <DataGridCheckBoxColumn Header="Certs" Binding="{Binding CanAccessTrackingCertificates}" Width="80" />
                            <DataGridCheckBoxColumn Header="Stock" Binding="{Binding CanAccessInventory}" Width="70" />
                            <DataGridCheckBoxColumn Header="Settings" Binding="{Binding CanAccessConnectivitySettings}" Width="90" />
                            <DataGridCheckBoxColumn Header="Users" Binding="{Binding CanManageUsers}" Width="70" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}"
                Padding="14">
            <Grid>
                <TextBlock x:Name="StatusTextBlock"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource SecondaryTextBrush}" />
                <Button Content="Close"
                        Width="130"
                        HorizontalAlignment="Right"
                        Click="OnClose" />
            </Grid>
        </Border>
    </Grid>
</Window>
