<Window x:Class="PurchaseOrderApp.WialonUnitDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="880"
        Width="1360"
        MinHeight="780"
        MinWidth="1180"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource HeroCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="96"
                            Height="96"
                            CornerRadius="22"
                            Background="White"
                            BorderBrush="#FFFFFF"
                            BorderThickness="1"
                            Padding="16"
                            Margin="0,0,18,0">
                        <Image Source="Assets/logo.png"
                               Stretch="Uniform" />
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding WindowTitle}"
                                   FontSize="28"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,8,0,0"
                                   FontSize="14"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Button Content="Close"
                            Width="120"
                            Click="OnCloseWindow" />
                </StackPanel>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="1"
                     Margin="0,18,0,16"
                     Columns="2">
            <Border Style="{StaticResource CardBorderStyle}"
                    Margin="0,0,8,0"
                    Background="{StaticResource CardBackgroundBrush}">
                <StackPanel>
                    <TextBlock Text="Connectivity settings"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="{Binding HardwareTypeDisplay, StringFormat=Device type: {0}}"
                               Margin="0,10,0,0"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding PhoneNumberDisplay, StringFormat=Phone: {0}}"
                               Margin="0,12,0,0"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding AccountDisplay, StringFormat=Account: {0}}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding UniqueIdDisplay, StringFormat=Unique ID: {0}}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SecondaryPhoneNumberDisplay, StringFormat=Secondary phone: {0}}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SecondaryUniqueIdDisplay, StringFormat=Secondary UID: {0}}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}"
                    Margin="8,0,0,0"
                    Background="{StaticResource AccentSoftBrush}">
                <StackPanel>
                    <TextBlock Text="Telemetry"
                               Style="{StaticResource SectionTitleStyle}" />
                    <TextBlock Text="{Binding HardwareTypeDisplay, StringFormat=Hardware type: {0}}"
                               Margin="0,10,0,0"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding LastMessageDisplay, StringFormat=Last message: {0}}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}" />
                    <TextBlock Text="{Binding LocationDisplay, StringFormat=Location: {0}}"
                               Margin="0,12,0,0"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="Profile, custom, and admin fields are listed below."
                               Margin="0,12,0,0"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="20,18,20,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Wialon Fields"
                                   Style="{StaticResource SectionTitleStyle}" />
                        <TextBlock Text="This table includes the unit profile data returned from Wialon, plus any custom and admin fields."
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{StaticResource CardTintBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,8"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding Fields.Count, StringFormat={}{0} fields loaded}"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </Border>
                </Grid>

                <DataGrid Grid.Row="1"
                          Margin="16,0,16,16"
                          ItemsSource="{Binding Fields}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Category"
                                            Binding="{Binding Category}"
                                            Width="140" />
                        <DataGridTextColumn Header="Field ID"
                                            Binding="{Binding FieldId}"
                                            Width="120" />
                        <DataGridTextColumn Header="Name"
                                            Binding="{Binding Name}"
                                            Width="240" />
                        <DataGridTextColumn Header="Value"
                                            Binding="{Binding Value}"
                                            Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,18,0,0"
                Style="{StaticResource CardBorderStyle}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Close"
                        Width="110"
                        Click="OnCloseWindow" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
